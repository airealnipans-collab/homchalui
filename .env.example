# ── หอมฉลุย env (Powered by 2T9COME) ──────────────────────────────
# Copy to .env and fill in. Validated by packages/config/env.ts (Zod).

# Core
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=th
NEXT_PUBLIC_SUPPORTED_LOCALES=th,en,zh

# Database (primary required; replica + pooler optional — see docs/SCALABILITY.md)
DATABASE_URL=postgresql://homchalui:homchalui@localhost:5432/homchalui?schema=public
DATABASE_REPLICA_URL=
DATABASE_POOL_URL=

# Redis (primary required; replica optional)
REDIS_URL=redis://localhost:6379
REDIS_REPLICA_URL=
REDIS_KEY_PREFIX=hc:

# Rate limiting (requests per minute)
RATE_LIMIT_SEARCH_PER_MIN=120
RATE_LIMIT_TRACK_PER_MIN=600
RATE_LIMIT_GO_PER_MIN=120

# Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Auth (backoffice)
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# Object storage (Cloudflare R2 / S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=homchalui-media
R2_PUBLIC_BASE_URL=

# Observability
SENTRY_DSN=

# Workers / jobs
RANKING_RECALC_CRON=0 * * * *
STATS_ROLLUP_CRON=15 * * * *
LINK_CHECK_CRON=0 3 * * *
SITEMAP_CRON=30 3 * * *
