# ── หอมฉลุย .gitignore (Powered by 2T9COME) ──

# Dependencies
node_modules/
.pnp.*
.yarn/*

# Build output
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo

# Env & secrets (NEVER commit) — only .env.example is tracked
.env
.env.*
!.env.example

# Prisma
packages/db/prisma/*.db
packages/db/prisma/migrations/dev.db*

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Test / coverage
coverage/
playwright-report/
test-results/

# Misc
*.local
.cache/
tmp/
